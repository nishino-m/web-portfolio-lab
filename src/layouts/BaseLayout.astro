---
import Header from "../components/Header.astro";
import SEO from "../components/SEO.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  type?: "website" | "article";
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  path,
  type = "website",
  image,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="zr_L6BxqQH_7nM6jLMkwi6B8D32fCpbweHtNemEOnds" />
    <meta name="theme-color" content="#2563eb" />
    <SEO
      title={title}
      description={description}
      path={path}
      type={type}
      image={image}
      noindex={noindex}
    />
  </head>

  <body>
    <Header />

    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <p>© Web系IT転職指南所</p>
        <p>Portfolio / Career / Web Development</p>
      </div>
    </footer>
  </body>
</html>